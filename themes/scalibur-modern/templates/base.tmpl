## -*- coding: utf-8 -*-
<%namespace name="base" file="base_helper.tmpl" import="*"/>
<%namespace name="header" file="base_header.tmpl" import="*"/>
<%namespace name="footer" file="base_footer.tmpl" import="*"/>
${set_locale(lang)}
${base.html_headstart()}
<%block name="extra_head">
### Leave this block alone.
</%block>
${template_hooks['extra_head']()}
<link rel="stylesheet" href="/assets/custom/index.css">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔭</text></svg>">
</head>
<body>

  <!-- Animated starfield -->
  <canvas id="starfield-canvas" aria-hidden="true"></canvas>

  <!-- ====== NAVBAR ====== -->
  <nav class="navbar" id="navbar">
    <div class="container">
      <a href="${_link("root", None, lang)}" class="nav-brand">
        <span class="brand-icon">🔭</span>
        ${blog_title|h}
      </a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="nav-links">
        %for url, text in navigation_links[lang]:
          % if isinstance(url, tuple):
            ## Submenu: render each sub-item as a top-level link
            %for suburl, subtext in url:
              <li><a href="${suburl}"${' class="active"' if rel_link(permalink, suburl) == "#" else ""}>${subtext}</a></li>
            %endfor
          % else:
            <li><a href="${url}"${' class="active"' if rel_link(permalink, url) == "#" else ""}>${text}</a></li>
          % endif
        %endfor
      </ul>
    </div>
  </nav>

  <!-- ====== CONTENT ====== -->
  <main id="content" style="padding-top: 80px; position: relative; z-index: 1;">
    <div class="container">
      <%block name="extra_header"></%block>
      <%block name="content"></%block>
    </div>
  </main>

  <!-- ====== FOOTER ====== -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <span class="footer-brand">🔭 ${blog_title|h}</span>
        <span class="footer-copy">© 1996 – 2026 Organización Scalibur para la Investigación y la Ciencia (O.S.I.)</span>
        <div class="footer-links">
          <a href="/corp/legal/" target="_blank" rel="noopener">Documentos legales</a>
          <a href="/rss.xml" target="_blank" rel="noopener">RSS</a>
        </div>
      </div>
    </div>
  </footer>

  ${base.late_load_js()}
  %if date_fanciness != 0:
      <!-- fancy dates -->
      <script>
      luxon.Settings.defaultLocale = "${luxon_locales[lang]}";
      fancydates(${date_fanciness}, ${luxon_date_format});
      </script>
      <!-- end fancy dates -->
  %endif
  <%block name="extra_js"></%block>
  <script>
  baguetteBox.run('main#content', {
      ignoreClass: 'islink',
      captions: function(element){var i=element.getElementsByTagName('img')[0];return i===undefined?'':i.alt;}});
  </script>
  <script src="/assets/custom/index.js"></script>
  ${body_end}
  ${template_hooks['body_end']()}
</body>
</html>
